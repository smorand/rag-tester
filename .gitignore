# =============================================================================
# PYTHON GITIGNORE TEMPLATE
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
wheels/
pip-wheel-metadata/
share/python-wheels/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.worktrees/

# Python version file
.python-version

# Tool caches
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pytest_cache/
.pytype/

# IDE
.idea/
.vscode/
*.swp
*.swo
.jukit/

# Jupyter Notebook
.ipynb_checkpoints

# celery beat schedule file
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# OS files
.DS_Store
Thumbs.db

# Ralph (story-driven development)
ralph.sh
ralph.yaml
stories.yaml
progress.md

# Log files
*.log

# Secrets (never commit)
*.pem
*.key
.env.local
.env.*.local

# NOTE: uv.lock is NOT ignored - it should be committed for reproducible builds
# NOTE: pyproject.toml is NOT ignored - it's the project configuration
